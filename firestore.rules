rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    match /birthday_configs/{configId} {
      // Anyone can get a public birthday experience using its unique configuration ID
      allow get: if true;
      
      // Allow creation with basic string boundary size enforcements to prevent Denial-of-Wallet attacks
      allow create: if request.resource.data.recipientName is string
                    && request.resource.data.recipientName.size() <= 128
                    && request.resource.data.passcode is string
                    && request.resource.data.passcode.size() <= 128;
                    
      // Prevent any unauthorized updates or tampering of already personalized birthday cards
      allow update, delete: if false;
    }
  }
}
